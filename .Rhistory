# Correlation circle colored by contribution
pdf("out/pdf/serious_search/acp_clustering/contrib_col_circle_1_2.pdf", width = 6, height = 5.9)
cor_circ12 <- fviz_pca_var(
res.PCA,
axes = c(1, 2),
col.var = "contrib",
gradient.cols = c("blue", "orange", "red"),
