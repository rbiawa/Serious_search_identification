# Spatial variable names for department and city
DEP_ID_VARIABLE      <- "dep_ID"
CITY_ID_VARIABLE     <- "sl_insee_city_id"
# Set the sample size for clustering (is set to 100 as default value)
SAMPLE_PROPORTION    <- 100 # in [0,100]
