as.data.table()
library(dplyr)
## Fonction utilitaire pour générer des IDs dynamiques
make_ids <- function(n, prefix = "2021") {
width <- nchar(n)
fmt <- paste0(prefix, "%0", width, "d")
sprintf(fmt, seq_len(n))
}
old_visitors <- unique(events$fullvisitorid)
new_visitors <- make_ids(length(old_visitors), prefix = "2021")
events$fullvisitorid     <- new_visitors[ match(events$fullvisitorid, old_visitors) ]
mail_phone$fullvisitorid <- new_visitors[ match(mail_phone$fullvisitorid, old_visitors) ]
View(events)
old_visits <- unique(events$visitid)
new_visits <- make_ids(length(old_visits), prefix = "2021")
events$visitid     <- new_visits[ match(events$visitid, old_visits) ]
mail_phone$visitid <- new_visits[ match(mail_phone$visitid, old_visits) ]
View(events)
old_listings <- unique(features$id_listing)
new_listings <- make_ids(length(old_listings), prefix = "2021")
events$id_listing     <- new_listings[ match(events$id_listing, old_listings) ]
mail_phone$id_listing <- new_listings[ match(mail_phone$id_listing, old_listings) ]
features$id_listing   <- new_listings[ match(features$id_listing, old_listings) ]
View(events)
View(events)
View(mail_phone)
length(is.na(old_listings))
length(!is.na(old_listings))
sum(is.na(old_listings))
View(features)
View(events)
